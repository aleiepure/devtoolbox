<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <requires lib="libadwaita" version="1.0" />
  <template class="HashGeneratorUtility" parent="AdwBin">
    <child>
      <object class="AdwToastOverlay" id="toast">
        <property name="child">
          <object class="GtkScrolledWindow">
            <property name="child">

              <object class="AdwClamp">
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>

                    <!-- Title bar -->
                    <child>
                      <object class="GtkGrid">
                        <child>
                          <object class="GtkButton" id="starred_btn">
                            <property name="icon-name">non-starred</property>
                            <property name="valign">center</property>
                            <property name="margin-top">10</property>
                            <style>
                              <class name="circular" />
                            </style>
                            <layout>
                              <property name="column">0</property>
                              <property name="row">0</property>
                              <property name="row-span">2</property>
                            </layout>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Hash generator</property>
                            <property name="halign">start</property>
                            <property name="margin-top">10</property>
                            <property name="margin-start">10</property>
                            <style>
                              <class name="title-1" />
                            </style>
                            <layout>
                              <property name="column">1</property>
                              <property name="row">0</property>
                            </layout>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Calculate hash strings from texts, images and files</property>
                            <property name="halign">start</property>
                            <property name="margin-start">10</property>
                            <style>
                              <class name="caption-heading" />
                            </style>
                            <layout>
                              <property name="column">1</property>
                              <property name="row">1</property>
                            </layout>
                          </object>
                        </child>

                      </object>
                    </child>

                    <!-- Divider -->
                    <child>
                      <object class="GtkSeparator">
                        <property name="margin-top">10</property>
                        <property name="margin-bottom">10</property>
                      </object>
                    </child>

                    <!-- Content -->
                    <!-- Options -->
                    <child>
                      <object class="AdwPreferencesGroup">
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Uppercase</property>
                            <property name="icon-name">format-text-rich-symbolic</property>
                            <child type="suffix">
                              <object class="GtkSwitch" id="uppercase_switch">
                                <property name="valign">center</property>
                                <property name="active">false</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwActionRow">
                            <property name="title" translatable="yes">Format</property>
                            <property name="subtitle" translatable="yes">Select the desired ouput format</property>
                            <property name="icon-name">grid-filled-symbolic</property>
                            <child type="suffix">
                              <object class="GtkDropDown" id="format_dropdown">
                                <property name="valign">center</property>
                                <property name="model">
                                  <object class="GtkStringList">
                                    <items>
                                      <item translatable="yes">Hex</item>
                                      <item translatable="yes">Binary</item>
                                      <item translatable="yes">Decimal</item>
                                    </items>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>

                    <!-- Input area -->
                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="margin-top">10</property>
                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>

                                <!-- Buttons bar -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="halign">fill</property>
                                    <property name="hexpand">true</property>
                                    <style>
                                      <class name="toolbar" />
                                    </style>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label" translatable="yes">Input</property>
                                        <property name="margin-bottom">8</property>
                                        <property name="margin-top">8</property>
                                        <property name="margin-start">8</property>
                                        <style>
                                          <class name="label" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">horizontal</property>
                                        <property name="halign">end</property>
                                        <property name="hexpand">true</property>
                                        <child>
                                          <object class="GtkBox">
                                            <property name="orientation">horizontal</property>
                                            <style>
                                              <class name="linked" />
                                            </style>
                                            <child>
                                              <object class="GtkButton" id="open_btn">
                                                <property name="valign">center</property>
                                                <property name="child">
                                                  <object class="AdwButtonContent">
                                                    <property name="icon-name">document-open-symbolic</property>
                                                    <property name="label" translatable="yes">Open</property>
                                                    <property name="use-underline">True</property>
                                                  </object>
                                                </property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton" id="paste_btn">
                                                <property name="valign">center</property>
                                                <property name="icon-name">edit-paste-symbolic</property>
                                                <property name="tooltip-text" translatable="yes">Paste clipboard</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton" id="clear_btn">
                                                <property name="valign">center</property>
                                                <property name="icon-name">edit-clear-symbolic</property>
                                                <property name="tooltip-text" translatable="yes">Clear input</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <!-- View area -->
                                <child>
                                  <object class="AdwViewStack" id="input_stack">
                                    <!-- Text view -->
                                    <child>
                                      <object class="AdwViewStackPage">
                                        <property name="name">text-view</property>
                                        <property name="child">
                                          <object class="GtkTextView" id="input_text">
                                            <property name="monospace">true</property>
                                            <property name="wrap-mode">word</property>
                                            <property name="height-request">200</property>
                                            <property name="top-margin">12</property>
                                            <property name="left-margin">12</property>
                                            <property name="right-margin">12</property>
                                            <property name="bottom-margin">12</property>
                                            <style>
                                              <class name="rounded-border" />
                                            </style>
                                          </object>
                                        </property>
                                      </object>
                                    </child>

                                    <!-- Image view -->
                                    <child>
                                      <object class="AdwViewStackPage">
                                        <property name="name">image-view</property>
                                        <property name="child">
                                          <object class="GtkPicture" id="input_image">
                                            <property name="can-shrink">true</property>
                                            <property name="keep-aspect-ratio">true</property>
                                            <style>
                                              <class name="rounded-border" />
                                              <class name="view" />
                                            </style>
                                          </object>
                                        </property>
                                      </object>
                                    </child>

                                    <!-- File view -->
                                    <child>
                                      <object class="AdwViewStackPage">
                                        <property name="name">file-view</property>
                                        <property name="child">
                                          <object class="GtkBox" id="input_file">
                                            <style>
                                              <class name="rounded-border" />
                                              <class name="view" />
                                            </style>
                                            <property name="orientation">vertical</property>
                                            <child>
                                              <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="valign">center</property>
                                                <property name="vexpand">true</property>
                                                <property name="spacing">10</property>
                                                <child>
                                                  <object class="GtkImage">
                                                    <property name="icon-name">paper-filled</property>
                                                    <property name="pixel-size">64</property>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkLabel" id="input_file_path_label">
                                                    <property name="label">/this/is/a/test/path</property>
                                                  </object>
                                                </child>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="AdwPreferencesGroup">
                        <property name="margin-top">10</property>
                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">MD5</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkText" id="md5_text">
                                        <property name="width-request">400</property>
                                        <property name="height-request">35</property>
                                        <property name="valign">center</property>
                                        <property name="editable">false</property>
                                        <style>
                                          <class name="view" />
                                          <class name="rounded-border" />
                                          <class name="padding-left-8" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSeparator">
                                        <style>
                                          <class name="spacer" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="md5_copy_btn">
                                        <style>
                                          <class name="raised" />
                                        </style>
                                        <property name="icon-name">edit-copy</property>
                                      </object>
                                    </child>
                                  </object>

                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">SHA1</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkText" id="sha1_text">
                                        <property name="width-request">400</property>
                                        <property name="height-request">35</property>
                                        <property name="valign">center</property>
                                        <property name="editable">false</property>
                                        <style>
                                          <class name="view" />
                                          <class name="rounded-border" />
                                          <class name="padding-left-8" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSeparator">
                                        <style>
                                          <class name="spacer" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="sha1_copy_btn">
                                        <style>
                                          <class name="raised" />
                                        </style>
                                        <property name="icon-name">edit-copy</property>
                                      </object>
                                    </child>
                                  </object>

                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">SHA256</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkText" id="sha256_text">
                                        <property name="width-request">400</property>
                                        <property name="height-request">35</property>
                                        <property name="valign">center</property>
                                        <property name="editable">false</property>
                                        <style>
                                          <class name="view" />
                                          <class name="rounded-border" />
                                          <class name="padding-left-8" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSeparator">
                                        <style>
                                          <class name="spacer" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="sha256_copy_btn">
                                        <style>
                                          <class name="raised" />
                                        </style>
                                        <property name="icon-name">edit-copy</property>
                                      </object>
                                    </child>
                                  </object>

                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesRow">
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">SHA512</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="GtkText" id="sha512_text">
                                        <property name="width-request">400</property>
                                        <property name="height-request">35</property>
                                        <property name="valign">center</property>
                                        <property name="editable">false</property>
                                        <style>
                                          <class name="view" />
                                          <class name="rounded-border" />
                                          <class name="padding-left-8" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkSeparator">
                                        <style>
                                          <class name="spacer" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="sha512_copy_btn">
                                        <style>
                                          <class name="raised" />
                                        </style>
                                        <property name="icon-name">edit-copy</property>
                                      </object>
                                    </child>
                                  </object>

                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>