<interface>
    <requires lib="gtk" version="4.0" />
    <requires lib="libadwaita" version="1.0" />
    <template class="EmptyFavorites" parent="AdwBin">
        <child>
            <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="vexpand">true</property>
                <property name="valign">center</property>
                <child>
                    <object class="GtkImage">
                        <property name="icon-name">starred</property>
                        <property name="pixel-size">120</property>
                    </object>
                </child>
                <child>
                    <object class="GtkLabel">
                        <style>
                            <class name="title-1" />
                        </style>
                        <property name="label" translatable="yes">Favorites</property>
                    </object>
                </child>
                <child>
                    <object class="GtkLabel">
                        <style>
                            <class name="title3" />
                        </style>
                        <property name="label" translatable="yes">Click the star button on your favorite utility to quickly find it in this tab</property>
                    </object>
                </child>
            </object>
        </child>
    </template>
</interface>