<?xml version="1.0" encoding="UTF-8"?>
<interface>
    <requires lib="gtk" version="4.0" />
    <requires lib="libadwaita" version="1.0" />
    <template class="CronParserUtility" parent="AdwBin">
        <child>
            <object class="AdwToastOverlay" id="toast">
                <property name="child">
                    <object class="GtkScrolledWindow">
                        <property name="child">

                            <object class="AdwClamp">
                                <property name="child">
                                    <object class="GtkBox">
                                        <property name="orientation">vertical</property>

                                        <!-- Title bar -->
                                        <child>
                                            <object class="GtkGrid">
                                                <child>
                                                    <object class="GtkButton" id="starred_btn">
                                                        <property name="icon-name">non-starred</property>
                                                        <property name="valign">center</property>
                                                        <property name="margin-top">10</property>
                                                        <style>
                                                            <class name="circular" />
                                                        </style>
                                                        <layout>
                                                            <property name="column">0</property>
                                                            <property name="row">0</property>
                                                            <property name="row-span">2</property>
                                                        </layout>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel">
                                                        <property name="label" translatable="yes">Cron parser</property>
                                                        <property name="halign">start</property>
                                                        <property name="margin-top">10</property>
                                                        <property name="margin-start">10</property>
                                                        <style>
                                                            <class name="title-1" />
                                                        </style>
                                                        <layout>
                                                            <property name="column">1</property>
                                                            <property name="row">0</property>
                                                        </layout>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="GtkLabel">
                                                        <property name="label" translatable="yes">Interpret cron expression to get the next date of execution</property>
                                                        <property name="halign">start</property>
                                                        <property name="margin-start">10</property>
                                                        <style>
                                                            <class name="caption-heading" />
                                                        </style>
                                                        <layout>
                                                            <property name="column">1</property>
                                                            <property name="row">1</property>
                                                        </layout>
                                                    </object>
                                                </child>

                                            </object>
                                        </child>

                                        <!-- Divider -->
                                        <child>
                                            <object class="GtkSeparator">
                                                <property name="margin-top">10</property>
                                                <property name="margin-bottom">10</property>
                                            </object>
                                        </child>

                                        <!-- Content -->
                                        <child>
                                            <object class="AdwPreferencesGroup">
                                                <child>
                                                    <object class="AdwActionRow">
                                                        <property name="title" translatable="yes">Scheduled dates</property>
                                                        <property name="subtitle" translatable="yes">Number of dates to be generated (up to 16)</property>
                                                        <property name="icon-name">today-alt-symbolic</property>
                                                        <child type="suffix">
                                                            <object class="GtkSpinButton" id="dates_spinner">
                                                                <property name="valign">center</property>
                                                                <property name="adjustment">
                                                                    <object class="GtkAdjustment">
                                                                        <property name="lower">1</property>
                                                                        <property name="upper">16</property>
                                                                        <property name="step-increment">1</property>
                                                                        <property name="value">5</property>
                                                                    </object>
                                                                </property>
                                                            </object>
                                                        </child>
                                                    </object>
                                                </child>
                                                <child>
                                                    <object class="AdwActionRow">
                                                        <property name="title" translatable="yes">Output format</property>
                                                        <property name="subtitle" translatable="yes">Format used to display generated dates (&lt;a href="https://strftime.org/"&gt;python syntax&lt;/a&gt;)</property>
                                                        <property name="icon-name">format-text-rich-symbolic</property>
                                                        <child type="suffix">
                                                            <object class="GtkText" id="format_text">
                                                                <property name="valign">center</property>
                                                                <property name="width-request">250</property>
                                                                <property name="height-request">30</property>
                                                                <property name="text">%c</property>
                                                                <style>
                                                                    <class name="view" />
                                                                    <class name="rounded-border" />
                                                                    <class name="padding-left-8" />
                                                                </style>
                                                            </object>
                                                        </child>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="AdwPreferencesGroup">
                                                <property name="margin-top">10</property>
                                                <child>
                                                    <object class="AdwPreferencesRow">
                                                        <child>
                                                            <object class="GtkBox">
                                                                <property name="orientation">vertical</property>

                                                                <!-- Buttons bar -->
                                                                <child>
                                                                    <object class="GtkBox">
                                                                        <property name="orientation">horizontal</property>
                                                                        <property name="halign">fill</property>
                                                                        <property name="hexpand">true</property>
                                                                        <style>
                                                                            <class name="toolbar" />
                                                                        </style>
                                                                        <child>
                                                                            <object class="GtkLabel">
                                                                                <property name="label" translatable="yes">Cron expression</property>
                                                                                <property name="margin-bottom">8</property>
                                                                                <property name="margin-top">8</property>
                                                                                <property name="margin-start">8</property>
                                                                                <style>
                                                                                    <class name="label" />
                                                                                </style>
                                                                            </object>
                                                                        </child>
                                                                        <child>
                                                                            <object class="GtkBox">
                                                                                <property name="orientation">horizontal</property>
                                                                                <property name="halign">end</property>
                                                                                <property name="hexpand">true</property>
                                                                                <child>
                                                                                    <object class="GtkBox">
                                                                                        <property name="orientation">horizontal</property>
                                                                                        <style>
                                                                                            <class name="linked" />
                                                                                        </style>
                                                                                        <child>
                                                                                            <object class="GtkButton" id="paste_btn">
                                                                                                <property name="valign">center</property>
                                                                                                <property name="icon-name">edit-paste-symbolic</property>
                                                                                                <property name="tooltip-text" translatable="yes">Paste from clipboard</property>
                                                                                            </object>
                                                                                        </child>
                                                                                        <child>
                                                                                            <object class="GtkButton" id="clear_btn">
                                                                                                <property name="valign">center</property>
                                                                                                <property name="icon-name">edit-clear-symbolic</property>
                                                                                                <property name="tooltip-text" translatable="yes">Clear expression</property>
                                                                                            </object>
                                                                                        </child>
                                                                                    </object>
                                                                                </child>
                                                                            </object>
                                                                        </child>

                                                                    </object>
                                                                </child>

                                                                <!-- Text Area -->
                                                                <child>
                                                                    <object class="GtkText" id="expression_text">
                                                                        <property name="width-request">200</property>
                                                                        <property name="height-request">30</property>
                                                                        <style>
                                                                            <class name="view" />
                                                                            <class name="rounded-border" />
                                                                            <class name="padding-left-8" />
                                                                        </style>
                                                                    </object>
                                                                </child>

                                                            </object>
                                                        </child>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                        <child>
                                            <object class="AdwPreferencesGroup">
                                                <property name="margin-top">10</property>
                                                <child>
                                                    <object class="AdwPreferencesRow">
                                                        <child>
                                                            <object class="GtkBox">
                                                                <property name="orientation">vertical</property>

                                                                <!-- Buttons bar -->
                                                                <child>
                                                                    <object class="GtkBox">
                                                                        <property name="orientation">horizontal</property>
                                                                        <property name="halign">fill</property>
                                                                        <property name="hexpand">true</property>
                                                                        <style>
                                                                            <class name="toolbar" />
                                                                        </style>
                                                                        <child>
                                                                            <object class="GtkLabel">
                                                                                <property name="label" translatable="yes">Next dates</property>
                                                                                <property name="margin-bottom">8</property>
                                                                                <property name="margin-top">8</property>
                                                                                <property name="margin-start">8</property>
                                                                                <style>
                                                                                    <class name="label" />
                                                                                </style>
                                                                            </object>
                                                                        </child>
                                                                        <child>
                                                                            <object class="GtkBox">
                                                                                <property name="orientation">horizontal</property>
                                                                                <property name="halign">end</property>
                                                                                <property name="hexpand">true</property>
                                                                                <child>
                                                                                    <object class="GtkButton" id="copy_btn">
                                                                                        <property name="valign">center</property>
                                                                                        <property name="icon-name">edit-copy-symbolic</property>
                                                                                        <property name="tooltip-text" translatable="yes">Copy to clipboard</property>
                                                                                        <style>
                                                                                            <class name="raised" />
                                                                                        </style>
                                                                                    </object>
                                                                                </child>
                                                                            </object>
                                                                        </child>

                                                                    </object>
                                                                </child>

                                                                <!-- Text Area -->
                                                                <child>
                                                                    <object class="GtkTextView" id="dates_text">
                                                                        <property name="monospace">true</property>
                                                                        <property name="wrap-mode">word</property>
                                                                        <property name="height-request">200</property>
                                                                        <property name="top-margin">12</property>
                                                                        <property name="left-margin">12</property>
                                                                        <property name="right-margin">12</property>
                                                                        <property name="bottom-margin">12</property>
                                                                        <property name="editable">false</property>
                                                                        <style>
                                                                            <class name="rounded-border" />
                                                                        </style>
                                                                    </object>
                                                                </child>

                                                            </object>
                                                        </child>
                                                    </object>
                                                </child>
                                            </object>
                                        </child>
                                    </object>
                                </property>
                            </object>
                        </property>
                    </object>
                </property>
            </object>

        </child>
    </template>
</interface>