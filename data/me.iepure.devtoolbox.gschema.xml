<schemalist gettext-domain="testt">
	<schema id="me.iepure.devtoolbox" path="/me/iepure/devtoolbox/">
		<key name="window-width" type="i">
			<default>1200</default>
		</key>
		<key name="window-height" type="i">
			<default>850</default>
		</key>
		<key name="window-maximized" type="b">
			<default>false</default>
		</key>
		<key name="favorites" type="as">
			<default>[]</default>
		</key>
		<key name="last-tab" type="s">
			<default>"converters"</default>
		</key>
		<key name="last-utility" type="s">
			<default>"json2yaml"</default>
		</key>
	</schema>
</schemalist>
